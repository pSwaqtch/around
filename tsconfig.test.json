{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "ES2022"],
    "strict": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": ".temp/test-dist",
    "types": ["node"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.d.ts", "src/lib/**/*.ts", "src/components/**/*.tsx", "tests/**/*.ts"]
}
